# c0rtex environment — secrets and configuration
# copy to .env and fill in real values
# loaded by c0rtex_paths.py at import time

# identity
CORTEX_USERNAME=user

# ollama
OLLAMA_HOST=http://localhost:11434

# matrix
MATRIX_HOMESERVER=http://localhost:8008
MATRIX_USER=@cortex:your.homeserver
MATRIX_ACCESS_TOKEN=your_matrix_access_token_here
MATRIX_ROOM_ID=!your_room_id:your.homeserver

# truenas
TRUENAS_HOST=http://192.168.1.201
TRUENAS_API_KEY=your_truenas_api_key_here

# unifi controller
UNIFI_HOST=https://192.168.1.1
UNIFI_USER=admin
UNIFI_PASS=your_unifi_password_here

# udm ssh (for ips monitor)
UDM_HOST=192.168.1.1
UDM_USER=root
SSH_KEY_PATH=~/.ssh/id_ed25519

# pinchtab browser bridge
PINCHTAB_BASE=http://127.0.0.1:9867

# oura ring (oauth2)
OURA_CLIENT_ID=your_oura_client_id
OURA_CLIENT_SECRET=your_oura_client_secret
OURA_REDIRECT_URI=http://127.0.0.1:5000/oura/callback
